# Copy to .env and adjust for your environment. docker-compose.yml reads
# these automatically; the defaults in docker-compose.yml match the local
# demo credentials documented in README.md.

DB_USER=cidecode
DB_PASSWORD=cidecode
DB_NAME=cidecode

# Set to True locally for uvicorn --reload / verbose SQL logging.
# Keep False for anything resembling a shared or production deployment.
DEBUG=False
